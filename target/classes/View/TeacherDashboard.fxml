<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="600.0" prefWidth="900.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.TeacherController">
  <children>

    <!-- Menu bar -->
    <MenuBar VBox.vgrow="NEVER">
      <menus>
        <Menu mnemonicParsing="false" text="File">
          <items>
            <MenuItem mnemonicParsing="false" text="Export as CSV" />
            <MenuItem mnemonicParsing="false" text="Quit" onAction="#handleLogout" />
          </items>
        </Menu>
        <Menu mnemonicParsing="false" text="View">
          <items>
            <MenuItem mnemonicParsing="false" text="Graph" />
          </items>
        </Menu>
        <Menu mnemonicParsing="false" text="Help">
          <items>
            <MenuItem mnemonicParsing="false" text="About" />
          </items>
        </Menu>
      </menus>
    </MenuBar>

    <!-- Logout button bar -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
      <padding><Insets top="5.0" bottom="5.0" right="10.0" /></padding>
      <children>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
      </children>
    </HBox>

    <!-- Main 3-panel split -->
    <SplitPane dividerPositions="0.25, 0.75"
               VBox.vgrow="ALWAYS">
      <items>

        <!-- Panel 1: Classes -->
        <AnchorPane>
          <children>
            <Label text="Classes" layoutX="14.0" layoutY="14.0">
              <font><Font size="18.0" fx:id="x1" /></font>
              <textFill><Color red="0.624" green="0.624" blue="0.624" fx:id="x2" /></textFill>
            </Label>
            <ListView fx:id="classListView"
                      layoutX="16.0" layoutY="47.0"
                      prefHeight="486.0" prefWidth="193.0" />
          </children>
        </AnchorPane>

        <!-- Panel 2: Students -->
        <ScrollPane prefHeight="551.0" prefWidth="360.0">
          <content>
            <AnchorPane minHeight="545.0" minWidth="430.0">
              <children>
                <Label text="Students" font="$x1" textFill="$x2"
                       layoutX="14.0" layoutY="14.0" />
                <ListView fx:id="studentListView"
                          layoutX="14.0" layoutY="50.0"
                          prefHeight="486.0" prefWidth="222.0" />
                <Button fx:id="addStudentButton"
                        layoutX="266.0" layoutY="54.0"
                        text="Add" onAction="#handleAddStudent" />
                <Button fx:id="delStudentButton"
                        layoutX="266.0" layoutY="105.0"
                        text="Del" onAction="#handleDeleteStudent" />
              </children>
            </AnchorPane>
          </content>
        </ScrollPane>

        <!-- Panel 3: Details + Grades -->
        <AnchorPane>
          <children>
            <Label text="Details" font="$x1" textFill="$x2"
                   layoutX="14.0" layoutY="14.0" />

            <Text layoutX="14.0"  layoutY="58.0"  text="First Name" />
            <Text fx:id="firstNameText" layoutX="14.0" layoutY="80.0" text="-" />

            <Text layoutX="116.0" layoutY="58.0"  text="Last Name" />
            <Text fx:id="lastNameText" layoutX="116.0" layoutY="80.0" text="-" />

            <Text layoutX="14.0"  layoutY="131.0" text="Age" />
            <Text fx:id="ageText" layoutX="14.0"  layoutY="153.0" text="-" />

            <Text layoutX="116.0" layoutY="131.0" text="Avg grades" />
            <Text fx:id="avgGradesText" layoutX="116.0" layoutY="153.0" text="-" />

            <!-- Grades section -->
            <Label text="Grades" font="$x1" textFill="$x2"
                   layoutX="14.0" layoutY="169.0" />
            <Button fx:id="addGradeButton"
                    layoutX="14.0" layoutY="197.0"
                    text="Add" onAction="#handleAddGrade" />
            <Button fx:id="delGradeButton"
                    layoutX="78.0" layoutY="197.0"
                    text="Del" onAction="#handleDeleteGrade" />
            <Button fx:id="editGradeButton"
                    layoutX="137.0" layoutY="197.0"
                    text="Edit" onAction="#handleEditGrade" />
            <ListView fx:id="gradesListView"
                      layoutX="10.0" layoutY="237.0"
                      prefHeight="281.0" prefWidth="200.0" />
          </children>
        </AnchorPane>

      </items>
    </SplitPane>
  </children>
</VBox>